# Backend environment variables (DO NOT commit real secrets)
PORT=5000

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=YOUR_STORAGE_BUCKET_NAME

# Email (Gmail app password recommended)
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password

# Optional
# CORS_ORIGIN=http://localhost:5173
# SERVE_FRONTEND=false

# Google manual sync (Plan A / no credentials)
# The portal can manually "Sync from Google" only if the Sheet/Doc link is public:
# - Share as "Anyone with the link can view" OR
# - Use "Publish to web"

# Google sync to Google Sheets/Docs (requires credentials + googleapis dependency)
# GOOGLE_SYNC_ENABLED=true
# Option A (inline JSON, recommended for servers): GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option B (json file path): GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
